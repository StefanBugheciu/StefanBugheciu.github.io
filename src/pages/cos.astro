---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Coșul meu - Atelier Săpun">
  <nav class="bg-white border-b border-pink-100 py-6 px-6 sticky top-0 z-50">
    <div class="max-w-4xl mx-auto flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 text-gray-500 hover:text-pink-500 transition-colors group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="font-medium tracking-wide">Înapoi la Magazin</span>
      </a>
      <span class="text-xl font-serif font-bold text-pink-500">Coșul tău</span>
    </div>
  </nav>

  <div class="min-h-screen py-12 px-6 bg-[#FFF5F7]">
    <div class="max-w-4xl mx-auto">
      
      <div id="empty-cart-msg" class="hidden text-center py-20 bg-white rounded-[3rem] shadow-xl">
        <div class="text-6xl mb-6">🌸</div>
        <h2 class="text-3xl font-serif font-bold text-gray-800 mb-4">Coșul tău este gol</h2>
        <a href="/" class="inline-block bg-pink-400 text-white px-8 py-4 rounded-2xl font-bold shadow-lg transition-transform hover:scale-105">Mergi la Produse</a>
      </div>

      <div id="cart-content" class="space-y-8 hidden">
        <div id="cart-items" class="space-y-4"></div>

        <div class="bg-white rounded-[3rem] p-8 shadow-xl border border-white">
          <div class="flex justify-between items-center mb-8 pb-6 border-b border-pink-50">
            <span class="text-gray-500 font-light">Total de plată</span>
            <span id="total-price" class="text-4xl font-serif font-bold text-gray-900">0 RON</span>
          </div>

          <div class="mb-8">
            <label class="block text-gray-500 text-sm mb-2 font-medium italic">Numele tău (pentru o notă personală)</label>
            <input type="text" id="user-name" placeholder="Ex: Maria Ionescu" class="w-full bg-pink-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-pink-300 outline-none transition-all" />
          </div>
          
          <div class="mb-8 flex items-start gap-3 bg-pink-50/50 p-4 rounded-2xl border border-pink-100">
            <span class="text-xl">📍</span>
            <div>
              <h4 class="font-bold text-gray-800 text-sm">Zonă de livrare: Exclusiv Brașov</h4>
              <p class="text-xs text-gray-500 mt-1">Momentan onorăm comenzile doar prin predare personală în Brașov. Vă mulțumim pentru înțelegere!</p>
            </div>
          </div>

          <button onclick="sendWhatsAppOrder()" class="w-full bg-green-500 hover:bg-green-600 text-white py-5 rounded-[2rem] font-bold text-lg shadow-lg flex justify-center items-center gap-3 transition-all active:scale-95">
            Finalizează Comanda pe WhatsApp
          </button>
          
          <p class="mt-4 text-center text-gray-400 text-xs italic">
             ✨ Fiind produse lucrate manual, te vom contacta pe WhatsApp pentru a confirma timpul exact de execuție.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div id="error-toast" class="fixed bottom-10 left-1/2 transform -translate-x-1/2 bg-white bg-opacity-90 backdrop-filter backdrop-blur-lg px-8 py-4 rounded-3xl shadow-[0_10px_40px_rgba(244,63,94,0.3)] opacity-0 translate-y-10 transition-all duration-300 pointer-events-none z-[100] flex items-center gap-4 border border-rose-200 min-w-[280px]">
    <div class="bg-rose-50 w-10 h-10 flex items-center justify-center rounded-2xl shadow-inner text-rose-400">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
    </div>
    <div class="flex flex-col text-left">
      <span class="text-[10px] uppercase tracking-widest text-rose-500 font-bold mb-1">Atenție</span>
      <span class="text-sm font-semibold text-gray-700">Te rugăm să introduci numele!</span>
    </div>
  </div>

  <script is:inline>
    // 1. Randarea coșului
    function renderCart() {
      const cart = JSON.parse(localStorage.getItem('cart')) || [];
      const cartItemsContainer = document.getElementById('cart-items');
      const emptyMsg = document.getElementById('empty-cart-msg');
      const cartContent = document.getElementById('cart-content');
      const totalPriceEl = document.getElementById('total-price');

      if (!cartItemsContainer) return; 

      if (cart.length === 0) {
        emptyMsg.classList.remove('hidden');
        cartContent.classList.add('hidden');
        return;
      }

      emptyMsg.classList.add('hidden');
      cartContent.classList.remove('hidden');
      
      let html = '';
      let total = 0;

      cart.forEach((item, index) => {
        total += item.price * item.quantity;
        
        html += `
          <div class="bg-white rounded-[2rem] p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 shadow-md border border-white">
            <div class="flex items-center gap-4 w-full sm:w-auto">
              <img src="${item.image}" class="w-20 h-20 sm:w-24 sm:h-24 object-cover rounded-2xl" />
              <div class="flex-grow">
                <h3 class="text-lg sm:text-xl font-serif font-bold text-gray-800 leading-tight">${item.name}</h3>
                <p class="text-pink-400 font-bold mt-1 text-sm sm:text-base">${item.price} lei / buc.</p>
              </div>
            </div>
            <div class="flex items-center justify-between w-full sm:w-auto mt-2 sm:mt-0 pt-2 sm:pt-0 border-t border-pink-50 sm:border-none">
              <div class="flex items-center gap-3 bg-pink-50 p-1.5 rounded-2xl">
                <button onclick="changeCartQty(${index}, -1)" class="w-8 h-8 rounded-xl bg-white text-gray-600 font-bold hover:bg-pink-100 transition-colors">-</button>
                <span class="font-bold text-gray-800 w-4 text-center">${item.quantity}</span>
                <button onclick="changeCartQty(${index}, 1)" class="w-8 h-8 rounded-xl bg-white text-gray-600 font-bold hover:bg-pink-100 transition-colors">+</button>
              </div>
              <button onclick="removeItem(${index})" class="text-gray-300 hover:text-red-400 transition-colors p-2 ml-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6" />
                </svg>
              </button>
            </div>
          </div>
        `;
      });

      cartItemsContainer.innerHTML = html;
      totalPriceEl.innerText = total + ' lei';
    }

    // 2. Modificarea Cantității și Ștergerea
    window.changeCartQty = function(index, delta) {
      let cart = JSON.parse(localStorage.getItem('cart'));
      cart[index].quantity += delta;
      if (cart[index].quantity < 1) cart[index].quantity = 1;
      localStorage.setItem('cart', JSON.stringify(cart));
      renderCart();
    };

    window.removeItem = function(index) {
      let cart = JSON.parse(localStorage.getItem('cart'));
      cart.splice(index, 1);
      localStorage.setItem('cart', JSON.stringify(cart));
      renderCart();
    };

    // 3. Notificarea vizuală de eroare
    function showErrorToast() {
      const toast = document.getElementById('error-toast');
      toast.classList.remove('opacity-0', 'translate-y-10');
      toast.classList.add('opacity-100', 'translate-y-0');
      
      setTimeout(() => {
        toast.classList.remove('opacity-100', 'translate-y-0');
        toast.classList.add('opacity-0', 'translate-y-10');
      }, 3000);
    }

    // 4. Finalizarea Comenzii
    window.sendWhatsAppOrder = function() {
      const cart = JSON.parse(localStorage.getItem('cart'));
      if (!cart || cart.length === 0) return;

      const nameInput = document.getElementById('user-name');
      const name = nameInput.value.trim();

      // Validarea numelui
      if (name === "") {
        showErrorToast();
        nameInput.focus();
        nameInput.classList.remove('focus:ring-pink-300');
        nameInput.classList.add('ring-2', 'ring-red-400', 'bg-red-50');
        setTimeout(() => {
          nameInput.classList.remove('ring-2', 'ring-red-400', 'bg-red-50');
          nameInput.classList.add('focus:ring-pink-300');
        }, 3000);
        return; 
      }

      let total = 0;
      const orderId = '#AS-' + Math.floor(1000 + Math.random() * 9000);
      
      let orderDetails = "";
      cart.forEach(item => {
        orderDetails += `${item.quantity} x ${item.name} (${item.price * item.quantity} lei), `;
        total += item.price * item.quantity;
      });

      // Email Backup către Formspree
      fetch("https://formspree.io/f/mkokjpkg", { 
        method: "POST",
        body: JSON.stringify({
            "ID Comandă": orderId,
            "Nume Client": name,
            "Comanda": orderDetails,
            "Total": total + " lei",
            "Mesaj": "Comandă inițiată de pe site"
        }),
        headers: { 'Content-Type': 'application/json' }
      }).catch(e => console.log(e));

      // WhatsApp Message Format
      let message = `Bună! Sunt ${name} și aș vrea să plasez comanda ${orderId}: \n\n`;
      cart.forEach(item => {
        message += `✅ ${item.quantity} x ${item.name} (${item.price * item.quantity} lei)\n`;
      });
      message += `\n💰 *Total de plată calculat: ${total} lei*`;
      message += `\n\n✨ În cât timp estimezi că ar fi gata?`;
      
      const whatsappUrl = `https://wa.me/40760635608?text=${encodeURIComponent(message)}`;
      window.open(whatsappUrl, '_blank');

      // Curățăm coșul și trimitem înapoi la magazin
      localStorage.removeItem('cart');
      window.location.href = "/succes"
    }

    // Încărcarea datelor la deschiderea paginii
    document.addEventListener('DOMContentLoaded', renderCart);
  </script>
</Layout>