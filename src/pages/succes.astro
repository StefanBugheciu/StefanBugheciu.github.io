---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Comandă trimisă - Bloom Atelier">
  <div class="min-h-screen flex items-center justify-center bg-[#FFF5F7] px-6 py-12">
    <div class="max-w-lg w-full bg-white rounded-[3rem] p-10 sm:p-12 text-center shadow-xl border border-white">
      
      <div class="w-24 h-24 rounded-[2rem] mx-auto mb-8 shadow-inner border border-pink-100 flex items-center justify-center bg-pink-50/50">
        <img src="/imagini/preview.jpg" alt="Previzualizare săpunuri artizanale Bloom Atelier" class="w-full h-full object-cover rounded-[2rem] shadow-lg animate-bounce" style="animation-iteration-count: 1;" />
      </div>
      
      <h1 class="text-3xl font-serif font-bold text-gray-800 mb-4">Comandă Inițiată!</h1>
      
      <p class="text-gray-600 mb-8 leading-relaxed text-sm sm:text-base">
        Îți mulțumim din suflet! Ne bucurăm enorm să pregătim ceva special pentru tine. 
        <br/><br/>
        Mesajul tău a fost deschis pe WhatsApp. Te rugăm să îl trimiți pentru a putea stabili detaliile finale și timpul de predare.
      </p>
      
      <a href="/" class="inline-block w-full bg-pink-400 hover:bg-pink-500 text-white font-bold py-4 rounded-2xl shadow-lg shadow-pink-200 transition-all active:scale-95">
        Întoarce-te la Magazin
      </a>
      
    </div>
  </div>
</Layout>